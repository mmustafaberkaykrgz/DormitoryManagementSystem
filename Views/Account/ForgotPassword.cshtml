@model DormitoryManagementSystem.Models.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — Dormitory System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; font-family: 'Outfit', sans-serif; }
        body {
            background: linear-gradient(135deg, #1a1a4e 0%, #25257a 50%, #1a1a4e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            overflow: hidden;
        }
        .login-card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 24px 64px rgba(26, 31, 94, 0.40);
            overflow: hidden;
            width: 440px;
            max-width: 100%;
        }
        .login-header {
            background: linear-gradient(135deg, #1A3A8A 0%, #3A6BC7 100%);
            padding: 32px 30px 26px;
            text-align: center;
            color: white;
            position: relative;
        }
        .login-header::after {
            content: '';
            position: absolute; bottom: -1px; left: 0; right: 0;
            height: 20px; background: white; border-radius: 20px 20px 0 0;
        }
        .login-header h3 { font-weight: 800; font-size: 1.4rem; margin: 0; }
        .login-body { padding: 20px 32px 32px; }
        
        .role-tabs {
            display: flex;
            background: #f0f4ff;
            border-radius: 12px;
            padding: 4px;
            margin-bottom: 24px;
            gap: 4px;
        }
        .role-tab {
            flex: 1;
            padding: 8px 4px;
            border: none;
            background: transparent;
            border-radius: 8px;
            font-weight: 700;
            font-size: 0.75rem;
            color: #6c7a9c;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .role-tab.active-admin { background: #1A3A8A; color: #FFD166; }
        .role-tab.active-staff { background: #2D7D4A; color: white; }
        .role-tab.active-student { background: #3A6BC7; color: white; }

        .form-label-custom { font-weight: 700; font-size: 0.72rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 6px; display: block; }
        .input-group { border-radius: 10px; overflow: hidden; }
        .input-group-text { background: #f8faff; border: 1.5px solid #dde3f0; color: #1A3A8A; }
        .form-control { background: #f8faff; border: 1.5px solid #dde3f0; border-left: none; padding: 11px 15px; font-size: 0.92rem; }
        .form-control:focus { border-color: #3A6BC7; box-shadow: none; background: white; }
        
        .btn-reset {
            background: linear-gradient(135deg, #1A3A8A, #3A6BC7);
            border: none; border-radius: 12px; padding: 12px;
            font-weight: 700; color: white; width: 100%;
            margin-top: 10px; transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(26,58,138,0.25);
        }
        .btn-reset:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(26,58,138,0.35); }
        
        .back-link { display: block; text-align: center; margin-top: 20px; font-size: 0.82rem; font-weight: 600; color: #64748b; text-decoration: none; transition: 0.2s; }
        .back-link:hover { color: #1A3A8A; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <h3>Reset Password</h3>
            <p style="font-size: 0.85rem; opacity: 0.8; margin-top: 4px;">Enter your details to receive a recovery link</p>
        </div>
        <div class="login-body">
            <form asp-action="ForgotPassword" method="post">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-3 py-2 small" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.5rem;"></button>
                    </div>
                }
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
                }

                <input type="hidden" asp-for="SelectedRole" id="selectedRoleInput" />
                <div class="role-tabs" id="roleTabs">
                    <button type="button" class="role-tab" data-role="Admin" onclick="selectRole(this,'Admin')">Admin</button>
                    <button type="button" class="role-tab" data-role="Staff" onclick="selectRole(this,'Staff')">Staff</button>
                    <button type="button" class="role-tab" data-role="Student" onclick="selectRole(this,'Student')">Student</button>
                </div>

                <div id="adminStaffFields">
                    <div class="mb-4">
                        <label class="form-label-custom">Username</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                            <input asp-for="Username" class="form-control" placeholder="Your username" />
                        </div>
                    </div>
                </div>

                <div id="studentFields" style="display:none;">
                    <div class="mb-4">
                        <label class="form-label-custom">Registration Number</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-fingerprint"></i></span>
                            <input asp-for="StudentId" class="form-control" placeholder="7-digit Ref No" maxlength="7" />
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-reset">
                    Send Recovery Link
                </button>

                <a asp-action="Login" class="back-link">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        const roleActiveClass = { 'Admin': 'active-admin', 'Staff': 'active-staff', 'Student': 'active-student' };
        function selectRole(btn, role) {
            document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active-admin', 'active-staff', 'active-student'));
            btn.classList.add(roleActiveClass[role]);
            document.getElementById('selectedRoleInput').value = role;
            if (role === 'Student') {
                document.getElementById('adminStaffFields').style.display = 'none';
                document.getElementById('studentFields').style.display = 'block';
            } else {
                document.getElementById('adminStaffFields').style.display = 'block';
                document.getElementById('studentFields').style.display = 'none';
            }
        }
        window.addEventListener('DOMContentLoaded', function () {
            var role = document.getElementById('selectedRoleInput').value || 'Admin';
            var tab = document.querySelector('[data-role="' + role + '"]');
            if (tab) selectRole(tab, role);
        });
    </script>
</body>
</html>
