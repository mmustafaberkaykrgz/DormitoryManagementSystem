@{
    Layout = null;
    ViewData["Title"] = "Email Simulation";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Email Simulation — Dormitory System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; font-family: 'Outfit', sans-serif; }
        body {
            background: #f1f5f9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .email-container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            width: 580px;
            max-width: 100%;
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }
        .email-header {
            background: #1e293b;
            color: white;
            padding: 20px 30px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .email-body {
            padding: 40px;
            color: #334155;
            line-height: 1.6;
        }
        .email-footer {
            background: #f8fafc;
            padding: 20px 40px;
            border-top: 1px solid #f1f5f9;
            color: #94a3b8;
            font-size: 0.8rem;
            text-align: center;
        }
        .simulation-banner {
            background: #fef9c3;
            color: #854d0e;
            padding: 10px 20px;
            font-size: 0.85rem;
            font-weight: 700;
            text-align: center;
            border-bottom: 2px solid #fde047;
        }
        .reset-button {
            display: inline-block;
            background: #3b82f6;
            color: white;
            padding: 14px 28px;
            border-radius: 8px;
            font-weight: 700;
            text-decoration: none;
            margin: 25px 0;
            transition: background 0.2s;
        }
        .reset-button:hover { background: #2563eb; color: white; }
        .token-box {
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            padding: 12px;
            border-radius: 6px;
            font-family: monospace;
            font-size: 0.9rem;
            word-break: break-all;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="simulation-banner">
            <i class="bi bi-cpu-fill me-2"></i> SYSTEM SIMULATION: This is how the email would look in production.
        </div>
        <div class="email-header">
            <div style="width:40px; height:40px; background:#3b82f6; border-radius:10px; display:flex; align-items:center; justify-content:center;">
                <i class="bi bi-shield-lock-fill" style="font-size:1.2rem;"></i>
            </div>
            <div>
                <div style="font-weight:800; font-size:1.1rem; line-height:1;">Dormitory System</div>
                <div style="font-size:0.75rem; opacity:0.7;">Security Notification</div>
            </div>
        </div>
        <div class="email-body">
            <h2 style="font-weight:800; color:#1e293b; margin-bottom:15px;">Password Reset Request</h2>
            <p>Hello,</p>
            <p>We received a request to reset the password for your account associated with the Dormitory Management System. If you didn't make this request, you can safely ignore this email.</p>
            
            <div style="text-align:center;">
                <a href="@ViewBag.ResetLink" class="reset-button">Reset My Password</a>
            </div>

            <p style="font-size:0.9rem;">This link will expire in <strong>1 hour</strong>. For security reasons, please do not share this link with anyone.</p>
            
            <p style="margin-top:30px; font-size:0.85rem; color:#64748b;">If the button above doesn't work, copy and paste the link below into your browser:</p>
            <div class="token-box">
                @ViewBag.ResetLink
            </div>
        </div>
        <div class="email-footer">
            &copy; @DateTime.Now.Year Dormitory Management System. All rights reserved. <br/>
            This is an automated system message.
        </div>
    </div>
</body>
</html>
