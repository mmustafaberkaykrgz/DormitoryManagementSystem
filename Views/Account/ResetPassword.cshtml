@model DormitoryManagementSystem.Models.ResetPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Set New Password — Dormitory System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; font-family: 'Outfit', sans-serif; }
        body {
            background: linear-gradient(135deg, #1a1a4e 0%, #25257a 50%, #1a1a4e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 24px 64px rgba(26, 31, 94, 0.40);
            overflow: hidden;
            width: 440px;
            max-width: 100%;
        }
        .login-header {
            background: linear-gradient(135deg, #1A3A8A 0%, #3A6BC7 100%);
            padding: 32px 30px 26px;
            text-align: center;
            color: white;
            position: relative;
        }
        .login-header::after {
            content: '';
            position: absolute; bottom: -1px; left: 0; right: 0;
            height: 20px; background: white; border-radius: 20px 20px 0 0;
        }
        .login-header h3 { font-weight: 800; font-size: 1.4rem; margin: 0; }
        .login-body { padding: 20px 32px 32px; }

        .form-label-custom { font-weight: 700; font-size: 0.72rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 6px; display: block; }
        .input-group { border-radius: 10px; overflow: hidden; }
        .input-group-text { background: #f8faff; border: 1.5px solid #dde3f0; color: #1A3A8A; }
        .form-control { background: #f8faff; border: 1.5px solid #dde3f0; border-left: none; padding: 11px 15px; font-size: 0.92rem; }
        .form-control:focus { border-color: #3A6BC7; box-shadow: none; background: white; }
        
        .btn-update {
            background: linear-gradient(135deg, #2D7D4A, #3DD172);
            border: none; border-radius: 12px; padding: 12px;
            font-weight: 700; color: white; width: 100%;
            margin-top: 10px; transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(45,125,74,0.25);
        }
        .btn-update:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(45,125,74,0.35); }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <h3>New Password</h3>
            <p style="font-size: 0.85rem; opacity: 0.8; margin-top: 4px;">Choose a secure password to protect your account</p>
        </div>
        <div class="login-body">
            <form asp-action="ResetPassword" method="post">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-3 py-2 small" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.5rem;"></button>
                    </div>
                }
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
                }

                <input type="hidden" asp-for="Token" />

                <div class="mb-4">
                    <label class="form-label-custom">New Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="At least 4 characters" id="pass1" />
                        <button type="button" class="input-group-text" onclick="togglePass('pass1')"><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label-custom">Confirm Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-check-circle-fill"></i></span>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" id="pass2" />
                        <button type="button" class="input-group-text" onclick="togglePass('pass2')"><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-update">
                    Update Password
                </button>
            </form>
        </div>
    </div>

    <script>
        function togglePass(id) {
            const inp = document.getElementById(id);
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
