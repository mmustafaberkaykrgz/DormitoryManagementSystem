@model IEnumerable<DormitoryManagementSystem.Models.DuesAndPenalty>
@{
    ViewData["Title"] = "Finances & Dues";
}

<div class="page-header" data-aos="fade-down">
    <div>
        <div class="page-title">Financial Tracking
            <span>Dues, payments & outstanding balances</span>
        </div>
    </div>
    @if (User.IsInRole("Staff"))
    {
        <a asp-action="Create" class="btn-primary-action" style="background:linear-gradient(135deg,#d97706,#f59e0b);">
            <i class="bi bi-plus-lg"></i> Add Due / Penalty
        </a>
    }
</div>

<!-- Finance Summary Chips -->
@{
    var totalPaid   = Model.Where(x => x.IsPaid).Sum(x => x.Amount);
    var totalUnpaid = Model.Where(x => !x.IsPaid).Sum(x => x.Amount);
}
<div class="d-flex gap-3 mb-4 flex-wrap" data-aos="fade-up" data-aos-delay="50">
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#f0fdf4;color:#2D7D4A;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-check-circle-fill"></i></div>
        <div>
            <div style="font-size:1.05rem;font-weight:800;color:#166534;">₺@totalPaid.ToString("N0")</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">COLLECTED</div>
        </div>
    </div>
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#fff1f2;color:#dc2626;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-exclamation-circle-fill"></i></div>
        <div>
            <div style="font-size:1.05rem;font-weight:800;color:#991b1b;">₺@totalUnpaid.ToString("N0")</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">OUTSTANDING</div>
        </div>
    </div>
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#fffbeb;color:#d97706;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-receipt"></i></div>
        <div>
            <div style="font-size:1.05rem;font-weight:800;color:#92400e;">@Model.Count()</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">TOTAL RECORDS</div>
        </div>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="100">
    <div class="table-card-header" style="background:linear-gradient(135deg,#d97706,#f59e0b);">
        <div class="table-card-title">
            <i class="bi bi-wallet2"></i> Financial Records
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th style="padding-left:20px; width: 22%;">Student Name</th>
                    <th style="width: 8%;">Room</th>
                    <th style="width: 13%;">Type</th>
                    <th style="width: 12%;">Amount (₺)</th>
                    <th style="width: 13%;">Status</th>
                    <th style="text-align:right;padding-right:20px; width: 32%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align:center;padding:48px 20px;color:#94a3b8;">
                            <i class="bi bi-wallet2" style="font-size:2.5rem;display:block;margin-bottom:10px;opacity:0.4;"></i>
                            No financial records found.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="padding-left:20px;">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div class="avatar-circle" style="width:28px;height:28px;border-radius:8px;font-size:0.75rem;background:linear-gradient(135deg,#d97706,#f59e0b);">
                                    @((item.Student?.FullName ?? "?").Substring(0,1).ToUpper())
                                </div>
                                <span style="font-weight:700;color:#1A1F5E;font-size:0.88rem;">@(item.Student?.FullName ?? "Unknown")</span>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border px-2 py-1" style="font-size:0.75rem;">
                                <i class="bi bi-door-closed me-1"></i>@(item.Student?.Room?.RoomNumber ?? "N/A")
                            </span>
                        </td>
                        <td>
                            <div style="font-size:0.82rem;font-weight:600;color:#64748b;">
                                @(item.Description.Length > 20 ? item.Description.Substring(0, 17) + "..." : item.Description)
                            </div>
                        </td>
                        <td>
                            <span style="font-size:0.95rem;font-weight:800;color:@(item.IsPaid ? "#166534" : "#991b1b");">
                                ₺@item.Amount.ToString("N2")
                            </span>
                        </td>
                        <td>
                            @if (item.IsPaid)
                            {
                                <span class="badge-resolved" style="padding:4px 10px;font-size:0.72rem;"><i class="bi bi-check-circle-fill me-1"></i>Paid</span>
                            }
                            else
                            {
                                <span style="background:rgba(220,38,38,0.1);color:#991b1b;font-weight:700;padding:4px 10px;border-radius:20px;font-size:0.72rem;">
                                    <i class="bi bi-x-circle-fill me-1"></i>Unpaid
                                </span>
                            }
                        </td>
                        <td style="text-align:right;padding-right:20px;">
                            <div style="display:inline-flex;align-items:center;gap:6px;flex-wrap:wrap;justify-content:flex-end;">
                                @if (User.IsInRole("Staff"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       style="display:inline-flex;align-items:center;gap:4px;padding:5px 11px;border-radius:8px;font-size:0.73rem;font-weight:700;background:rgba(99,102,241,0.1);color:#4338ca;text-decoration:none;border:1px solid rgba(99,102,241,0.25);transition:all .2s;"
                                       onmouseover="this.style.background='rgba(99,102,241,0.2)'" onmouseout="this.style.background='rgba(99,102,241,0.1)'">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                }
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   style="display:inline-flex;align-items:center;gap:4px;padding:5px 11px;border-radius:8px;font-size:0.73rem;font-weight:700;background:rgba(14,165,233,0.1);color:#0369a1;text-decoration:none;border:1px solid rgba(14,165,233,0.25);transition:all .2s;"
                                   onmouseover="this.style.background='rgba(14,165,233,0.2)'" onmouseout="this.style.background='rgba(14,165,233,0.1)'">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                                @if (User.IsInRole("Staff"))
                                {
                                    @if (!item.IsPaid)
                                    {
                                        <form asp-action="MarkAsPaid" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn-action btn-resolve" style="padding:5px 11px;font-size:0.73rem;">
                                                <i class="bi bi-check2"></i> Mark Paid
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span style="color:#94a3b8;font-size:0.73rem;"><i class="bi bi-check-all"></i> Settled</span>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
