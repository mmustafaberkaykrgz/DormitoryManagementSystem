@model DormitoryManagementSystem.Models.MaintenanceTicket
@{
    ViewData["Title"] = "Edit Ticket";
}

<div class="page-header" data-aos="fade-down">
    <div>
        <div class="page-title">Edit Maintenance Ticket
            <span>Update your service request details</span>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="bi bi-arrow-left me-2"></i> Cancel
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 20px;" data-aos="fade-up" data-aos-delay="50">
    <div class="card-body p-5">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="mb-4">
                <label asp-for="Issue" class="form-label fw-bold" style="color: #1A1F5E;">Issue Description <span class="text-danger">*</span></label>
                <textarea asp-for="Issue" class="form-control bg-light border-0 p-3" rows="5" placeholder="Please describe the maintenance issue in detail..." required></textarea>
                <span asp-validation-for="Issue" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end border-top pt-4 mt-2">
                <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">
                    <i class="bi bi-save me-2"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
