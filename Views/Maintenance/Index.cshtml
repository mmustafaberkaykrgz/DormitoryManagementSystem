@model IEnumerable<DormitoryManagementSystem.Models.MaintenanceTicket>
@{
    ViewData["Title"] = "Maintenance Tickets";
}

<div class="page-header" data-aos="fade-down">
    <div>
        <div class="page-title">Maintenance Tickets
            <span>Service & repair request tracking</span>
        </div>
    </div>
    @if (User.IsInRole("Student"))
    {
        if (ViewBag.IsActiveStudent == true)
        {
            <a asp-action="Create" class="btn-primary-action">
                <i class="bi bi-plus-lg"></i> File New Ticket
            </a>
        }
    }
</div>

<!-- Status Summary -->
<div class="d-flex gap-3 mb-4 flex-wrap" data-aos="fade-up" data-aos-delay="50">
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#fff7ed;color:#d97706;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-clock-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#92400e;">@ViewBag.PendingCount</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">PENDING</div>
        </div>
    </div>
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#f0fdf4;color:#2D7D4A;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-check-circle-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#166534;">@ViewBag.ResolvedCount</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">RESOLVED</div>
        </div>
    </div>
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#eff6ff;color:#1A3A8A;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-ticket-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#1A1F5E;">@ViewBag.TotalCount</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">TOTAL</div>
        </div>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="100">
    <div class="table-card-header" style="background:linear-gradient(135deg,#1A1F5E,#1A3A8A);">
        <div class="table-card-title">
            <i class="bi bi-tools"></i> All Tickets
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th style="padding-left:20px;">Ticket ID</th>
                    <th>Reporter</th>
                    <th>Room</th>
                    <th>Issue</th>
                    <th>Status</th>
                    <th style="text-align:right;padding-right:20px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center;padding:48px 20px;color:#94a3b8;">
                            <i class="bi bi-tools" style="font-size:2.5rem;display:block;margin-bottom:10px;opacity:0.4;"></i>
                            No maintenance tickets found.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="padding-left:20px;">
                            <span style="font-family:monospace;font-weight:700;color:#1A3A8A;background:#eff6ff;padding:4px 10px;border-radius:6px;font-size:0.85rem;">
                                #@item.Id.ToString("D5")
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div class="avatar-circle" style="width:34px;height:34px;border-radius:9px;font-size:0.82rem;background:linear-gradient(135deg,#1A3A8A,#3A6BC7);">
                                    @((item.Student?.FullName ?? "?").Substring(0,1).ToUpper())
                                </div>
                                <div style="font-weight:600;color:#1A1F5E;font-size:0.9rem;">@(item.Student?.FullName ?? "Unknown")</div>
                            </div>
                        </td>
                        <td>
                            <span class="badge-room"><i class="bi bi-door-open me-1"></i>@(item.Room?.RoomNumber ?? "N/A")</span>
                        </td>
                        <td>
                            <div style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#475569;font-size:0.9rem;" title="@item.Issue">
                                @item.Issue
                            </div>
                        </td>
                        <td>
                            @if (item.IsResolved)
                            {
                                <span class="badge-resolved"><i class="bi bi-check-circle-fill me-1"></i>Resolved</span>
                            }
                            else
                            {
                                <span class="badge-pending">
                                    <i class="bi bi-clock me-1"></i>Pending
                                </span>
                            }
                        </td>
                        <td style="text-align:right;padding-right:20px;">
                            <div style="display:flex; gap:6px; justify-content:flex-end; align-items:center;">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-view"><i class="bi bi-eye"></i> View</a>
                                @if (User.IsInRole("Student"))
                                {
                                    @if (!item.IsResolved)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit"><i class="bi bi-pencil"></i></a>
                                    }
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn-action btn-delete" onclick="return confirmDelete(this.form, 'Are you sure you want to permanently delete this maintenance ticket?')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                }
                                @if (User.IsInRole("Staff"))
                                {
                                    @if (!item.IsResolved)
                                    {
                                        <form asp-action="Resolve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn-action" style="background:#f0fdf4; color:#166534; border:1px solid #dcfce7; padding:5px 12px; border-radius:10px; font-size:0.8rem; font-weight:700;">
                                                <i class="bi bi-check-lg"></i> Mark Resolved
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span style="color:#94a3b8;font-size:0.8rem;margin-left:8px;"><i class="bi bi-check-all"></i> Done</span>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    int pCurrentPage = (int)(ViewBag.CurrentPage ?? 1);
    int pTotalPages  = (int)(ViewBag.TotalPages  ?? 1);
    int pTotalCount  = (int)(ViewBag.TotalCount  ?? 0);
    string pLabel = "records";
}
@if (pTotalPages > 1)
{
    <div class="d-flex justify-content-center align-items-center gap-2 mt-4" data-aos="fade-up" data-aos-delay="150" style="margin-bottom: 24px;">
        @if (pCurrentPage > 1)
        {
            <a href="@Url.Action("Index", new { page = pCurrentPage - 1 })"
               style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:white;color:#1A1F5E;text-decoration:none;border:1.5px solid #e2e8f0;box-shadow:0 2px 8px rgba(26,31,94,0.06);transition:all .2s;"
               onmouseover="this.style.borderColor='#f59e0b'" onmouseout="this.style.borderColor='#e2e8f0'">
                <i class="bi bi-chevron-left"></i> Prev
            </a>
        }
        else
        {
            <span style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:#f8faff;color:#cbd5e1;border:1.5px solid #f1f5f9;">
                <i class="bi bi-chevron-left"></i> Prev
            </span>
        }

        @for (int i = 1; i <= pTotalPages; i++)
        {
            if (i == pCurrentPage)
            {
                <span style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:10px;font-size:0.85rem;font-weight:800;background:#f59e0b;color:white;box-shadow:0 4px 12px rgba(245,158,11,0.35);">
                    @i
                </span>
            }
            else
            {
                <a href="@Url.Action("Index", new { page = i })"
                   style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:10px;font-size:0.85rem;font-weight:700;background:white;color:#475569;text-decoration:none;border:1.5px solid #e2e8f0;transition:all .2s;"
                   onmouseover="this.style.borderColor='#f59e0b';this.style.color='#f59e0b'" onmouseout="this.style.borderColor='#e2e8f0';this.style.color='#475569'">
                    @i
                </a>
            }
        }

        @if (pCurrentPage < pTotalPages)
        {
            <a href="@Url.Action("Index", new { page = pCurrentPage + 1 })"
               style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:white;color:#1A1F5E;text-decoration:none;border:1.5px solid #e2e8f0;box-shadow:0 2px 8px rgba(26,31,94,0.06);transition:all .2s;"
               onmouseover="this.style.borderColor='#f59e0b'" onmouseout="this.style.borderColor='#e2e8f0'">
                Next <i class="bi bi-chevron-right"></i>
            </a>
        }
        else
        {
            <span style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:#f8faff;color:#cbd5e1;border:1.5px solid #f1f5f9;">
                Next <i class="bi bi-chevron-right"></i>
            </span>
        }
    </div>
    <div class="text-center" style="font-size:0.78rem;color:#94a3b8;font-weight:500;margin-bottom: 24px;">
        Page @pCurrentPage of @pTotalPages &nbsp;&middot;&nbsp; @pTotalCount @pLabel total
    </div>
}
