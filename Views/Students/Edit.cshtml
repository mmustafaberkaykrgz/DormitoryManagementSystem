@model DormitoryManagementSystem.Models.Student
@{
    ViewData["Title"] = "Update Student";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-9">
        <div class="text-center mb-4">
            <h2 class="fw-bolder" style="color: #2c3e50;">Update Student Profile</h2>
            <p class="text-muted">Modify student details, room allocation, or contract duration.</p>
        </div>

        <div class="card border-0 shadow-lg" style="border-radius: 20px;">
            <div class="card-body p-5">
                <form asp-action="Edit" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UserId" />

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="First name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Surname" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="Surname" class="form-control form-control-lg bg-light border-0" placeholder="Last name" />
                            <span asp-validation-for="Surname" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StudentId" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="StudentId" class="form-control form-control-lg bg-light border-0" placeholder="7-digit registration number" maxlength="7" />
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="Email" class="form-control form-control-lg bg-light border-0" placeholder="student@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg bg-light border-0" placeholder="+90 5XX XXX XX XX" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-secondary">Assigned Room</label>
                            <div class="custom-select-container">
                                <input id="roomSearchInput" class="form-control form-control-lg bg-light border-0" 
                                       placeholder="Type room number to search..." 
                                       autocomplete="off" 
                                       required />
                                <div id="roomListDropdown" class="custom-select-dropdown">
                                    @foreach (var r in ViewBag.Rooms)
                                    {
                                        <div class="custom-select-option" data-id="@r.Id" data-value="@r.RoomNumber">
                                            <span class="room-number">@r.RoomNumber</span>
                                            <span class="room-info">@(r.DisplayText.Replace(r.RoomNumber.ToString() + " - ", ""))</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <input type="hidden" asp-for="RoomId" id="roomIdHidden" />
                            <span asp-validation-for="RoomId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="MembStartDate" class="form-label fw-bold text-secondary">Contract Start</label>
                            <input asp-for="MembStartDate" type="text" class="form-control form-control-lg bg-light border-0 flatpickr-date" placeholder="Select Start Date" />
                            <span asp-validation-for="MembStartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MembEndDate" class="form-label fw-bold text-secondary">Contract End</label>
                            <input asp-for="MembEndDate" type="text" class="form-control form-control-lg bg-light border-0 flatpickr-date" placeholder="Select End Date" />
                            <span asp-validation-for="MembEndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const ps = new PremiumSelect('roomSearchInput', 'roomListDropdown', 'roomIdHidden');
        
        // Initialize if editing
        const hiddenId = document.getElementById('roomIdHidden').value;
        if (hiddenId) {
            const initialOption = document.querySelector(`.custom-select-option[data-id="${hiddenId}"]`);
            if (initialOption) {
                document.getElementById('roomSearchInput').value = initialOption.getAttribute('data-value');
            }
        }
    });
</script>
