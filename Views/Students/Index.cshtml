@model IEnumerable<DormitoryManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Students Roster";
}

<div class="page-header" data-aos="fade-down">
    <div>
        <div class="page-title">Students Roster
            <span>Manage all registered residents</span>
        </div>
    </div>
    <div class="d-flex flex-column gap-2">
        @if (User.IsInRole("Staff"))
        {
            <a asp-action="Create" class="btn-primary-action">
                <i class="bi bi-person-plus-fill"></i> Register Student
            </a>
        }
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i> Back to Roster
                </a>
            }
            <button type="button" class="btn btn-outline-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#searchStudentModal">
                <i class="bi bi-search me-2"></i> Search Student
            </button>
        }
    </div>
</div>

<!-- Summary Chips -->
<div class="d-flex gap-3 mb-4 flex-wrap" data-aos="fade-up" data-aos-delay="50">
    <div style="background:white; border-radius:12px; padding:10px 18px; box-shadow:0 2px 12px rgba(26,31,94,0.07); display:flex; align-items:center; gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#eff6ff;color:#1A3A8A;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-people-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#1A1F5E;">@ViewBag.GlobalTotal</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">TOTAL</div>
        </div>
    </div>
    <div style="background:white; border-radius:12px; padding:10px 18px; box-shadow:0 2px 12px rgba(26,31,94,0.07); display:flex; align-items:center; gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#f0fdf4;color:#2D7D4A;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-person-check-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#166534;">@ViewBag.GlobalActive</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">ACTIVE</div>
        </div>
    </div>
    <div style="background:white; border-radius:12px; padding:10px 18px; box-shadow:0 2px 12px rgba(26,31,94,0.07); display:flex; align-items:center; gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#fffbeb;color:#b45309;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-person-dash-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#92400e;">@ViewBag.GlobalPassive</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">PASSIVE</div>
        </div>
    </div>
    <div style="background:white; border-radius:12px; padding:10px 18px; box-shadow:0 2px 12px rgba(26,31,94,0.07); display:flex; align-items:center; gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#f8faff;color:#94a3b8;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-person-x-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#64748b;">@ViewBag.GlobalExpired</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">EXPIRED</div>
        </div>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="100">
    <div class="table-card-header">
        <div class="table-card-title">
            <i class="bi bi-person-badge-fill"></i> All Students
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th style="padding-left:20px;">Student</th>
                    <th>Registration Number</th>
                    <th>E-Mail</th>
                    <th>Room</th>
                    <th>Membership Period</th>
                    <th>Status</th>
                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                    {
                        <th style="text-align:right; padding-right:20px;">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center; padding:48px 20px; color:#94a3b8;">
                            <i class="bi bi-people" style="font-size:2.5rem; display:block; margin-bottom:10px; opacity:0.4;"></i>
                            No students found.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="padding-left:20px;">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div class="avatar-circle" style="background:linear-gradient(135deg,#3A6BC7,#5B72FF);">
                                    @(string.IsNullOrEmpty(item.Name) ? "?" : item.Name.Substring(0,1).ToUpper())
                                </div>
                                <div>
                                    <div style="font-weight:700; color:#1A1F5E;">@item.Name @item.Surname</div>
                                    <div style="font-size:0.78rem; color:#94a3b8;">@item.User?.Username</div>
                                </div>
                            </div>
                        </td>
                        <td style="font-family:monospace; color:#64748b; font-size:0.88rem;">@item.StudentId</td>
                        <td style="color:#64748b; font-size:0.88rem;">@item.Email</td>
                        <td>
                            <span class="badge-room"><i class="bi bi-door-open me-1"></i>@(item.Room?.RoomNumber ?? "Unassigned")</span>
                        </td>
                        <td>
                            <div style="font-size:0.8rem; color:#94a3b8;">
                                <i class="bi bi-calendar3 me-1"></i>
                                @item.MembStartDate.ToString("dd MMM yy", System.Globalization.CultureInfo.GetCultureInfo("en-US")) → @item.MembEndDate.ToString("dd MMM yy", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                            </div>
                        </td>
                        <td>
                            @{
                                var now = DateTime.Now;
                                if (item.MembStartDate > now)
                                {
                                    <span style="display:inline-flex;align-items:center;gap:5px;background:#fffbeb;color:#92400e;padding:4px 10px;border-radius:20px;font-size:0.78rem;font-weight:700;">
                                        <i class="bi bi-clock-fill" style="font-size:0.55rem;"></i> Passive
                                    </span>
                                }
                                else if (item.MembEndDate >= now)
                                {
                                    <span class="badge-active"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge-expired">Expired</span>
                                }
                            }
                        </td>
                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                        {
                            <td style="text-align:right; padding-right:20px;">
                                <div style="display:flex; gap:6px; justify-content:flex-end;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-view"><i class="bi bi-eye"></i> View</a>
                                    @if (User.IsInRole("Staff"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn-action btn-delete" onclick="return confirmDelete(this.form, 'Are you sure you want to permanently delete this student record?')">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    int pCurrentPage = (int)(ViewBag.CurrentPage ?? 1);
    int pTotalPages  = (int)(ViewBag.TotalPages  ?? 1);
    int pTotalCount  = (int)(ViewBag.TotalCount  ?? 0);
    string? pSearch  = ViewBag.SearchTerm as string;
    string pController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Index";
    string pLabel = pController == "Rooms" ? "rooms" : "students";
}
@if (pTotalPages > 1)
{
    <div class="d-flex justify-content-center align-items-center gap-2 mt-4" data-aos="fade-up" data-aos-delay="150">
        @if (pCurrentPage > 1)
        {
            <a href="@Url.Action("Index", new { page = pCurrentPage - 1, search = pSearch })"
               style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:white;color:#1A1F5E;text-decoration:none;border:1.5px solid #e2e8f0;box-shadow:0 2px 8px rgba(26,31,94,0.06);transition:all .2s;"
               onmouseover="this.style.borderColor='#3A6BC7'" onmouseout="this.style.borderColor='#e2e8f0'">
                <i class="bi bi-chevron-left"></i> Prev
            </a>
        }
        else
        {
            <span style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:#f8faff;color:#cbd5e1;border:1.5px solid #f1f5f9;">
                <i class="bi bi-chevron-left"></i> Prev
            </span>
        }
        @for (int i = 1; i <= pTotalPages; i++)
        {
            if (i == pCurrentPage)
            {
                <span style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:10px;font-size:0.85rem;font-weight:800;background:linear-gradient(135deg,#1A3A8A,#3A6BC7);color:white;box-shadow:0 4px 12px rgba(26,58,138,0.35);">
                    @i
                </span>
            }
            else
            {
                <a href="@Url.Action("Index", new { page = i, search = pSearch })"
                   style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:10px;font-size:0.85rem;font-weight:700;background:white;color:#475569;text-decoration:none;border:1.5px solid #e2e8f0;transition:all .2s;"
                   onmouseover="this.style.borderColor='#3A6BC7';this.style.color='#1A3A8A'" onmouseout="this.style.borderColor='#e2e8f0';this.style.color='#475569'">
                    @i
                </a>
            }
        }
        @if (pCurrentPage < pTotalPages)
        {
            <a href="@Url.Action("Index", new { page = pCurrentPage + 1, search = pSearch })"
               style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:white;color:#1A1F5E;text-decoration:none;border:1.5px solid #e2e8f0;box-shadow:0 2px 8px rgba(26,31,94,0.06);transition:all .2s;"
               onmouseover="this.style.borderColor='#3A6BC7'" onmouseout="this.style.borderColor='#e2e8f0'">
                Next <i class="bi bi-chevron-right"></i>
            </a>
        }
        else
        {
            <span style="display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:10px;font-size:0.82rem;font-weight:700;background:#f8faff;color:#cbd5e1;border:1.5px solid #f1f5f9;">
                Next <i class="bi bi-chevron-right"></i>
            </span>
        }
    </div>
    <div class="text-center mt-2" style="font-size:0.78rem;color:#94a3b8;font-weight:500;">
        Page @pCurrentPage of @pTotalPages &nbsp;&middot;&nbsp; @pTotalCount @pLabel total
    </div>
}
@section Scripts {
    <!-- Search Modal -->
    <div class="modal fade" id="searchStudentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-0 p-4 pb-0">
                    <h5 class="modal-title fw-bold" style="color: #1A1F5E;">Search Student</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="Index" method="get">
                    <div class="modal-body p-4">
                        <p class="text-muted small mb-4">Search by Dormitory Registration Number, First Name, or Last Name to find a specific resident.</p>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" name="search" class="form-control bg-light border-0" placeholder="Registration No or Name">
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">Search Now</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
